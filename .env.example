# Copy this to .env.local and fill in the values you need.

# ── Vercel KV (optional) ──────────────────────────────────────────────────────
# Without these the app uses in-memory storage (progressions reset on restart).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Song import: AI chord detection (optional) ────────────────────────────────
# Provide ONE of these to enable "AI chord detection" in the import sheet.
# Gemini 1.5 Flash is recommended (~$0.001 per song, supports audio input).
GEMINI_API_KEY=
# OPENAI_API_KEY=   ← not yet wired up; add /api/analyze-openai if you prefer GPT-4o

# ── Song import: Spotify key/BPM lookup (optional) ────────────────────────────
# Create a free app at https://developer.spotify.com/dashboard
# NOTE: The audio-features endpoint is restricted for apps created after Nov 2024.
# Existing apps still work. Key & BPM from audio file upload always works for free.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
